  <?xml version="1.0" encoding="UTF-8"?>
  <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
      "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
  <plist version="1.0">
  <dict>
      <key>Label</key>
      <string>net.surguy.octopusviz</string>

      <key>ProgramArguments</key>
      <array>
          <string>/usr/bin/java</string>
          <string>-jar</string>
          <string>/opt/octopus/octopusviz.jar</string>
      </array>

      <key>WorkingDirectory</key>
      <string>/opt/octopus</string>

      <key>RunAtLoad</key>
      <true/>

      <key>KeepAlive</key>
      <true/>

      <key>StandardOutPath</key>
      <string>/var/log/octopus/stdout.log</string>

      <key>StandardErrorPath</key>
      <string>/var/log/octopus/stderr.log</string>
  </dict>
  </plist>